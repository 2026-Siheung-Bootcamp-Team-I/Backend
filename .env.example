# alert 모듈 환경변수 예시 — 이 파일을 .env 로 복사한 뒤 실제 값으로 채운다.
# Spring Boot 는 .env 를 자동으로 읽지 않으므로 실행 전에 셸에 주입한다:
#   export $(grep -v '^#' .env | xargs)
#   ./gradlew :alert:bootRun
# (IDE 실행 구성의 Environment variables 에 넣어도 된다.)

# Slack Incoming Webhook URL. 미설정 시 alert 모듈은 발송을 skip 하고 경고 로그만 남긴다.
# 형식: https://hooks.slack.com/services/<workspace>/<channel>/<token>
SLACK_WEBHOOK_URL=
